rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /responses/{responseId} {
      allow read: if request.auth != null; // Dashboard needs to read all responses
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /deliveryLogs/{logId} {
      allow read: if request.auth != null; // Dashboard needs to read delivery logs
      allow write: if request.auth != null;
    }

    match /zones/{zoneId} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend creates/updates
    }

    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow create, delete: if false; // Created by backend automation only
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Audit logs: allow authenticated writes/reads for observability
    match /auditLogs/{logId} {
      allow read, write: if request.auth != null;
    }

    match /volunteers/{volunteerId} {
      // Allow any logged-in user (including authorities) to read volunteer profiles
      allow read: if request.auth != null;
      // Dashboard UI can update volunteer fields (activation, status)
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
